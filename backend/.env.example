# Postgres
POSTGRES_DB=riftapp
POSTGRES_USER=riftapp
POSTGRES_PASSWORD=<strong password>

# MinIO / S3
S3_ACCESS_KEY=riftapp
S3_SECRET_KEY=<strong password>
S3_BUCKET=riftapp
S3_PUBLIC_URL=https://<your-domain>/s3

# Auth
JWT_SECRET=<run: openssl rand -hex 32>
ALLOWED_ORIGINS=https://riftapp.io,https://www.riftapp.io

# LiveKit
LIVEKIT_URL=wss://livekit.<your-domain>
LIVEKIT_API_KEY=<run: openssl rand -hex 16>
LIVEKIT_API_SECRET=<run: openssl rand -hex 32>
